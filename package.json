{
  "name": "luma-agent",
  "version": "0.1.0",
  "description": "Lean Luma event evaluation monorepo with a secure MCP helper and local cache",
  "type": "module",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspace @luma-agent/shared && npm run build --workspace @luma-agent/helper && npm run build --workspace @luma-agent/cli",
    "test": "npm run test --workspace @luma-agent/helper && npm run test --workspace @luma-agent/cli",
    "sync:gmail": "npm run sync:gmail --workspace @luma-agent/cli",
    "refresh:events": "npm run refresh:events --workspace @luma-agent/cli",
    "render:content": "npm run render:content --workspace @luma-agent/cli",
    "report:upcoming": "npm run report:upcoming --workspace @luma-agent/cli",
    "run:daily": "npm run run:daily --workspace @luma-agent/cli"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/thunderberry/luma-agent.git"
  },
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/thunderberry/luma-agent/issues"
  },
  "homepage": "https://github.com/thunderberry/luma-agent#readme",
  "devDependencies": {
    "@types/node": "^24.10.0",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vitest": "^4.0.0"
  },
  "engines": {
    "node": ">=20"
  }
}
